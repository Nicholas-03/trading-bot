# Alpaca credentials — used for real-time news feed and entry-confirmation bars (not for trading)
ALPACA_API_KEY=your_alpaca_api_key
ALPACA_SECRET_KEY=your_alpaca_secret_key
# Market data feed for entry-confirmation bars: iex, sip, delayed_sip, or otc.
# Use sip if your Alpaca plan includes it; iex is the safest free default.
ALPACA_DATA_FEED=iex

# Tradier credentials — used for all trading
TRADIER_ACCESS_TOKEN=your_tradier_access_token
TRADIER_ACCOUNT_ID=your_tradier_account_id
TRADIER_PAPER=true
# Optional: real (live) account token for real-time quotes while paper trading.
# Sandbox quotes are 15-min delayed; set this to get accurate prices for position sizing.
TRADIER_LIVE_TOKEN=

# LLM provider: ChatGPT / OpenAI only
LLM_PROVIDER=chatgpt
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-5.4-mini

TRADE_AMOUNT_USD=5.0
ALLOW_SHORT=false
SHORT_QTY=1
STOP_LOSS_PCT=2
TAKE_PROFIT_PCT=3
MIN_CONFIDENCE=0.7

# Entry quality guards
MAX_SLIPPAGE_PCT=0.5
EXTENDED_MOVE_LOW_PRICE_PCT=15.0
EXTENDED_MOVE_ANY_PCT=10.0
MIN_TRADE_PRICE=5.0
DEFAULT_HOLD_HOURS=4
MAX_HOLD_HOURS=4
BLOCK_SOFT_PARTNERSHIP_NEWS=true
BRACKET_REPRICE_ENABLED=true
ENTRY_CONFIRMATION_ENABLED=true
ENTRY_CONFIRMATION_LOOKBACK_MINUTES=8
ENTRY_CONFIRMATION_TREND_MINUTES=3
ENTRY_CONFIRMATION_MAX_FADE_PCT=1.5
ENTRY_CONFIRMATION_MAX_QUOTE_PREMIUM_PCT=1.0
FAST_FAIL_ENABLED=true
FAST_FAIL_MINUTES=5
FAST_FAIL_LOSS_PCT=1.5
FAST_FAIL_MIN_FAVORABLE_PCT=0.25
EARLY_FAILURE_ENABLED=true
EARLY_FAILURE_MINUTES=30
EARLY_FAILURE_MIN_FAVORABLE_PCT=0.5
PROFIT_LOCK_ENABLED=true
PROFIT_LOCK_BREAKEVEN_PCT=2.0
PROFIT_LOCK_TRAILING_START_PCT=3.0
PROFIT_LOCK_TRAILING_GAP_PCT=1.25
NEWS_STALE_HOURS=2.0

# Telegram notifications
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
