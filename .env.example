# Alpaca credentials — used for real-time news feed only (not for trading)
ALPACA_API_KEY=your_alpaca_api_key
ALPACA_SECRET_KEY=your_alpaca_secret_key

# Tradier credentials — used for all trading
TRADIER_ACCESS_TOKEN=your_tradier_access_token
TRADIER_ACCOUNT_ID=your_tradier_account_id
TRADIER_PAPER=true
# Optional: real (live) account token for real-time quotes while paper trading.
# Sandbox quotes are 15-min delayed; set this to get accurate prices for position sizing.
TRADIER_LIVE_TOKEN=

# LLM provider: "claude", "gemini", "deepseek", "chatgpt", or "multi"
LLM_PROVIDER=gemini

# Claude (required if LLM_PROVIDER=claude)
ANTHROPIC_API_KEY=your_anthropic_api_key
ANTHROPIC_MODEL=claude-opus-4-6

# Gemini (required if LLM_PROVIDER=gemini)
GOOGLE_API_KEY=your_google_api_key
GEMINI_MODEL=gemini-2.0-flash

# DeepSeek (required if LLM_PROVIDER=deepseek)
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_MODEL=deepseek-chat

# ChatGPT / OpenAI (required if LLM_PROVIDER=chatgpt or multi)
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o

TRADE_AMOUNT_USD=5.0
ALLOW_SHORT=false
SHORT_QTY=1
STOP_LOSS_PCT=2
TAKE_PROFIT_PCT=3
MIN_CONFIDENCE=0.7

# Entry quality guards
MAX_SLIPPAGE_PCT=1.0
EXTENDED_MOVE_LOW_PRICE_PCT=15.0
EXTENDED_MOVE_ANY_PCT=20.0
NEWS_STALE_HOURS=2.0

# Telegram notifications
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
